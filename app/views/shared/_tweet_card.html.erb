<article id="tweet_<%= tweet.id %>" class="flex gap-3 px-4 py-3 hover:bg-gray-50/80 border-b border-gray-100 transition-colors">
  <% display_tweet = tweet.retweet? ? tweet.original_tweet : tweet %>
  <div class="flex flex-col items-center flex-shrink-0">
    <%= link_to user_path(tweet.user.username), class: "flex-shrink-0" do %>
      <%= avatar_tag(tweet.user, size: :md) %>
    <% end %>
  </div>

  <div class="flex-1 min-w-0">
    <% if tweet.retweet? %>
      <p class="text-xs text-gray-500 mb-1 flex items-center gap-1">
        <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        <%= tweet.user.display_name %>さんがリツイート
      </p>
    <% end %>

    <div class="flex items-center gap-1 flex-wrap">
      <%= link_to user_path(display_tweet.user.username), class: "font-bold hover:underline text-sm flex items-center gap-1" do %>
        <%= display_tweet.user.display_name %>
        <%= render "shared/pro_badge", user: display_tweet.user %>
      <% end %>
      <span class="text-gray-500 text-sm">@<%= display_tweet.user.username %></span>
      <span class="text-gray-400">·</span>
      <%= link_to tweet_path(display_tweet), class: "text-gray-500 text-sm hover:underline" do %>
        <%= relative_time(display_tweet.created_at) %>
      <% end %>
      <% if display_tweet.user == current_user %>
        <div class="ml-auto" data-controller="dropdown">
          <button class="p-1 rounded-full hover:bg-sky-100 hover:text-sky-500 text-gray-400 transition-colors" data-action="click->dropdown#toggle">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M6 10a2 2 0 11-4 0 2 2 0 014 0zM12 10a2 2 0 11-4 0 2 2 0 014 0zM16 12a2 2 0 100-4 2 2 0 000 4z"/></svg>
          </button>
          <div class="absolute right-0 mt-1 w-40 bg-white border border-gray-200 rounded-xl shadow-lg hidden z-50" data-dropdown-target="menu" data-action="click@window->dropdown#close">
            <%= button_to tweet_path(display_tweet), method: :delete, data: { turbo_confirm: "削除しますか？" }, class: "w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 rounded-xl" do %>
              削除
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-0.5 text-[15px] leading-normal break-words"><%= format_tweet_body(display_tweet.body) %></div>

    <% if display_tweet.media.attached? %>
      <div class="mt-3 rounded-2xl overflow-hidden border border-gray-100 grid gap-0.5 <%= display_tweet.media.count == 1 ? '' : display_tweet.media.count == 2 ? 'grid-cols-2' : display_tweet.media.count == 3 ? 'grid-cols-2' : 'grid-cols-2' %>">
        <% display_tweet.media.each_with_index do |media_file, i| %>
          <% if media_file.content_type.start_with?("image/") %>
            <%= image_tag url_for(media_file), class: "w-full object-cover #{display_tweet.media.count == 1 ? 'max-h-80' : 'h-40'}", loading: "lazy" %>
          <% elsif media_file.content_type.start_with?("video/") %>
            <video src="<%= url_for(media_file) %>" controls class="w-full object-cover <%= display_tweet.media.count == 1 ? 'max-h-80' : 'h-40' %>"></video>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# Action bar %>
    <div class="flex items-center justify-between mt-3 max-w-[80%] text-gray-500">
      <%# Reply %>
      <%= link_to tweet_path(display_tweet), class: "flex items-center gap-1.5 hover:text-sky-500 group transition-colors" do %>
        <span class="p-1.5 rounded-full group-hover:bg-sky-100 transition-colors">
          <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 01-.923 1.785A5.969 5.969 0 006 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337z"/></svg>
        </span>
        <span class="text-sm"><%= display_tweet.replies_count %></span>
      <% end %>

      <%# Retweet %>
      <%= render "tweets/retweet_btn", tweet: display_tweet, current_user: current_user %>

      <%# Like %>
      <%= render "tweets/like_btn", tweet: display_tweet, current_user: current_user %>

      <%# Bookmark %>
      <%= render "tweets/bookmark_btn", tweet: display_tweet, current_user: current_user %>
    </div>
  </div>
</article>
