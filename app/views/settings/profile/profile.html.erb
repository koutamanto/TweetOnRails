<div class="sticky top-0 bg-white/80 backdrop-blur-sm border-b border-gray-100 px-4 py-3 z-10 flex items-center gap-4">
  <%= link_to settings_profile_path, class: "p-2 rounded-full hover:bg-gray-100 transition-colors -ml-2" do %>
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
  <% end %>
  <h1 class="font-bold text-xl">プロフィールを編集</h1>
</div>

<div class="p-4">
  <%= form_with model: @user, url: settings_profile_path, method: :patch, multipart: true, class: "space-y-5" do |f| %>
    <%# Header image %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">ヘッダー画像</label>
      <div class="h-32 bg-sky-100 rounded-xl overflow-hidden relative cursor-pointer hover:opacity-80 transition-opacity">
        <% if @user.header_image.attached? %>
          <%= image_tag url_for(@user.header_image), class: "w-full h-full object-cover" %>
        <% end %>
        <label class="absolute inset-0 flex items-center justify-center cursor-pointer">
          <span class="bg-black/40 text-white text-xs px-3 py-1.5 rounded-full">変更</span>
          <%= f.file_field :header_image, class: "hidden", accept: "image/*" %>
        </label>
      </div>
    </div>

    <%# Avatar %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">アイコン</label>
      <div class="relative w-20 h-20 cursor-pointer">
        <%= avatar_tag(@user, size: :xl) %>
        <label class="absolute inset-0 flex items-center justify-center rounded-full bg-black/40 cursor-pointer opacity-0 hover:opacity-100 transition-opacity">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>
          <%= f.file_field :avatar, class: "hidden", accept: "image/*" %>
        </label>
      </div>
    </div>

    <div>
      <%= f.label :display_name, "表示名", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :display_name, class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
    </div>

    <div>
      <%= f.label :bio, "自己紹介", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :bio, rows: 3, maxlength: 160, placeholder: "自己紹介を入力（160文字以内）", class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition resize-none" %>
    </div>

    <div>
      <%= f.label :location, "場所", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :location, placeholder: "例：東京, 日本", class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
    </div>

    <div>
      <%= f.label :website, "ウェブサイト", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.url_field :website, placeholder: "https://example.com", class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
    </div>

    <div class="pt-2">
      <%= f.submit "保存", class: "w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-full transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
