<div class="max-w-lg mx-auto px-6 py-10">
  <h1 class="text-2xl font-bold mb-8">お支払い・プラン</h1>

  <%# Stripe test mode banner %>
  <% if stripe_test_mode? %>
    <div class="flex items-center gap-2 bg-amber-50 border border-amber-300 text-amber-800 rounded-xl px-4 py-3 mb-6 text-sm font-semibold">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
      </svg>
      Stripe テストモード稼働中
    </div>
  <% end %>

  <% if current_user.pro? %>
    <%# Active Pro card %>
    <div class="border-2 border-amber-300 bg-amber-50 rounded-2xl p-6 mb-6">
      <div class="flex items-start justify-between mb-4">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <svg class="w-5 h-5 text-amber-400" viewBox="0 0 24 24">
              <path fill="currentColor" d="M12 2L3 6.5V12c0 5.25 3.83 9.54 9 10.93C17.17 21.54 21 17.25 21 12V6.5L12 2Z"/>
              <path fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M8.5 12l2.5 2.5 4.5-5"/>
            </svg>
            <span class="font-bold text-amber-700">Robin Pro</span>
          </div>
          <p class="text-sm text-amber-600">プレミアムプランご利用中</p>
        </div>
        <span class="text-xs font-bold uppercase bg-amber-400 text-white px-2.5 py-1 rounded-full">有効</span>
      </div>

      <div class="space-y-2 text-sm text-gray-600 mb-5">
        <% if current_user.subscription_current_period_end.present? %>
          <div class="flex justify-between">
            <span>次回請求日</span>
            <span class="font-semibold"><%= current_user.subscription_current_period_end.strftime("%Y年%m月%d日") %></span>
          </div>
        <% end %>
        <div class="flex justify-between">
          <span>ステータス</span>
          <% status_label = case current_user.subscription_status
            when "active"   then ["有効", "text-green-600"]
            when "past_due" then ["支払い遅延", "text-red-600"]
            when "canceled" then ["キャンセル済み", "text-gray-500"]
            else [current_user.subscription_status.to_s, "text-gray-600"]
          end %>
          <span class="font-semibold <%= status_label[1] %>"><%= status_label[0] %></span>
        </div>
        <%# Infer interval from price ID %>
        <% if current_user.stripe_subscription_id.present? %>
          <div class="flex justify-between">
            <span>プランタイプ</span>
            <span class="font-semibold text-gray-700">
              <% yearly_price_id = ENV["STRIPE_PRO_YEARLY_PRICE_ID"] %>
              <%# We detect yearly by checking period length (>300 days) as a proxy %>
              <% if current_user.subscription_current_period_end.present? &&
                    (current_user.subscription_current_period_end - Time.current) > 300.days %>
                年払い（¥9,800/年）
              <% else %>
                月払い（¥980/月）
              <% end %>
            </span>
          </div>
        <% end %>
      </div>

      <%= link_to "プランを管理・キャンセル", billing_portal_path, class: "block w-full text-center border border-amber-400 hover:bg-amber-100 text-amber-700 font-semibold text-sm py-2.5 rounded-full transition-colors" %>
      <p class="text-xs text-amber-500 text-center mt-2">Stripe カスタマーポータルに移動します</p>
    </div>

    <%# Pro features list %>
    <div class="bg-gray-50 rounded-xl p-5">
      <p class="text-sm font-semibold text-gray-700 mb-3">現在の特典</p>
      <ul class="space-y-2 text-sm text-gray-600">
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-sky-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          ツイート 500文字
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-sky-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          自己紹介 320文字
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-sky-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          金色プロバッジ表示
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-sky-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          誰にでもDM送信可能
        </li>
      </ul>
    </div>

  <% else %>
    <%# Free user — upgrade CTA %>
    <div class="border border-gray-200 rounded-2xl p-6 mb-6">
      <p class="text-sm text-gray-500 mb-1 uppercase tracking-wide font-semibold">現在のプラン</p>
      <p class="text-2xl font-bold text-gray-800 mb-1">無料</p>
      <p class="text-sm text-gray-500 mb-6">ツイート 280文字 · 自己紹介 160文字</p>
      <%= link_to "Robin Pro にアップグレード", pricing_path, class: "block w-full text-center bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-full text-sm transition-colors" %>
    </div>

    <div class="bg-sky-50 border border-sky-100 rounded-xl p-5">
      <p class="font-semibold text-sky-800 mb-1 text-sm">Robin Pro で得られること</p>
      <p class="text-xs text-sky-600">ツイート500文字、プロバッジ、誰にでもDM、優先表示。¥980/月から。</p>
    </div>
  <% end %>

  <div class="mt-8 pt-6 border-t border-gray-100">
    <%= link_to "← 設定に戻る", settings_profile_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
</div>
