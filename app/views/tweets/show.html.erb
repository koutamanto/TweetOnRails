<div class="sticky top-0 bg-white/80 backdrop-blur-sm border-b border-gray-100 px-4 py-3 z-10 flex items-center gap-4">
  <%= link_to :back, class: "p-2 rounded-full hover:bg-gray-100 transition-colors -ml-2" do %>
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
  <% end %>
  <h1 class="font-bold text-xl">ツイート</h1>
</div>

<% display_tweet = @tweet.retweet? ? @tweet.original_tweet : @tweet %>

<div class="px-4 py-4 border-b border-gray-100">
  <div class="flex items-center gap-3 mb-3">
    <%= link_to user_path(display_tweet.user.username) do %>
      <%= avatar_tag(display_tweet.user, size: :md) %>
    <% end %>
    <div>
      <%= link_to display_tweet.user.display_name, user_path(display_tweet.user.username), class: "font-bold hover:underline block" %>
      <span class="text-gray-500 text-sm">@<%= display_tweet.user.username %></span>
    </div>
    <% if display_tweet.user == current_user %>
      <div class="ml-auto" data-controller="dropdown">
        <button class="p-2 rounded-full hover:bg-gray-100 text-gray-500 transition-colors" data-action="click->dropdown#toggle">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M6 10a2 2 0 11-4 0 2 2 0 014 0zM12 10a2 2 0 11-4 0 2 2 0 014 0zM16 12a2 2 0 100-4 2 2 0 000 4z"/></svg>
        </button>
        <div class="absolute right-4 mt-1 w-44 bg-white border border-gray-200 rounded-xl shadow-lg hidden z-50" data-dropdown-target="menu" data-action="click@window->dropdown#close">
          <%= button_to tweet_path(display_tweet), method: :delete,
                data: { turbo_confirm: "このツイートを削除しますか？" },
                class: "w-full text-left px-4 py-3 text-sm text-red-600 hover:bg-red-50 rounded-xl flex items-center gap-2" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            削除する
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-[17px] leading-relaxed mb-3 break-words"><%= format_tweet_body(display_tweet.body) %></div>

  <% if display_tweet.media.attached? %>
    <div class="rounded-2xl overflow-hidden border border-gray-100 mb-3 grid gap-0.5 <%= display_tweet.media.count == 1 ? '' : 'grid-cols-2' %>">
      <% display_tweet.media.each do |media_file| %>
        <% if media_file.content_type.start_with?("image/") %>
          <%= image_tag url_for(media_file), class: "w-full object-cover max-h-96" %>
        <% elsif media_file.content_type.start_with?("video/") %>
          <video src="<%= url_for(media_file) %>" controls class="w-full max-h-96"></video>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <p class="text-sm text-gray-500 py-3 border-t border-gray-100">
    <%= display_tweet.created_at.strftime("%Y年%m月%d日 %H:%M") %>
  </p>

  <div class="flex gap-6 py-3 border-t border-gray-100 text-sm">
    <span><strong><%= display_tweet.retweets_count %></strong> <span class="text-gray-500">リツイート</span></span>
    <span><strong><%= display_tweet.likes_count %></strong> <span class="text-gray-500">いいね</span></span>
    <span><strong><%= display_tweet.bookmarks_count %></strong> <span class="text-gray-500">ブックマーク</span></span>
  </div>

  <div class="flex items-center justify-around py-2 border-t border-gray-100 text-gray-500">
    <%= render "tweets/retweet_btn", tweet: display_tweet, current_user: current_user %>
    <%= render "tweets/like_btn", tweet: display_tweet, current_user: current_user %>
    <%= render "tweets/bookmark_btn", tweet: display_tweet, current_user: current_user %>
  </div>
</div>

<%# Reply form %>
<div class="border-b border-gray-100 p-4">
  <%= form_with model: Tweet.new, url: tweet_replies_path(display_tweet), class: "flex gap-3" do |f| %>
    <div class="flex-shrink-0"><%= avatar_tag(current_user, size: :md) %></div>
    <div class="flex-1">
      <%= f.text_area :body, placeholder: "返信をツイート",
            rows: 2,
            class: "w-full resize-none border-0 outline-none text-base placeholder-gray-400 bg-transparent" %>
      <div class="flex justify-end mt-2">
        <%= f.submit "返信", class: "bg-sky-500 hover:bg-sky-600 text-white font-bold px-5 py-1.5 rounded-full text-sm transition-colors cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>

<%# Replies %>
<div id="replies">
  <% @replies.each do |reply| %>
    <%= render "shared/tweet_card", tweet: reply, current_user: current_user %>
  <% end %>
</div>
<% if @replies.empty? %>
  <div class="text-center py-12 text-gray-400">
    <p class="text-sm">まだ返信がありません</p>
  </div>
<% end %>
