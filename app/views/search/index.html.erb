<div class="sticky top-0 bg-white/80 backdrop-blur-sm border-b border-gray-100 px-4 py-3 z-10">
  <%= form_with url: search_path, method: :get, local: true do |f| %>
    <div class="relative">
      <svg class="absolute left-3 top-2.5 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z"/>
      </svg>
      <%= f.search_field :q, placeholder: "検索", value: @query, autofocus: true, class: "w-full pl-10 pr-4 py-2.5 bg-gray-100 hover:bg-gray-200 focus:bg-white rounded-full text-sm border border-transparent focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
    </div>
  <% end %>
</div>

<% if @query.present? %>
  <% if @users.any? %>
    <div class="border-b border-gray-100">
      <div class="px-4 py-3">
        <h2 class="font-bold text-base">ユーザー</h2>
      </div>
      <% @users.each do |user| %>
        <%= render "users/user_row", user: user, current_user: current_user %>
      <% end %>
    </div>
  <% end %>

  <% if @tweets.any? %>
    <div>
      <div class="px-4 py-3">
        <h2 class="font-bold text-base">ツイート</h2>
      </div>
      <% @tweets.each do |tweet| %>
        <%= render "shared/tweet_card", tweet: tweet, current_user: current_user %>
      <% end %>
    </div>
  <% elsif @users.empty? %>
    <div class="text-center py-16">
      <p class="font-bold text-xl mb-2">「<%= @query %>」の検索結果がありません</p>
      <p class="text-gray-500 text-sm">別のキーワードをお試しください</p>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-16 text-gray-400">
    <p class="font-medium">キーワードを入力してください</p>
  </div>
<% end %>
