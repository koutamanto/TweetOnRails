<div class="px-4 py-6 max-w-2xl">
  <h1 class="text-xl font-bold mb-6">支払い・Stripe 設定</h1>

  <%# Stripe test mode banner %>
  <% if stripe_test_mode? %>
    <div class="flex items-center gap-2 bg-amber-50 border border-amber-300 text-amber-800 rounded-xl px-4 py-3 mb-6 text-sm font-semibold">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
      </svg>
      Stripe テストモード稼働中 — 実際の決済は処理されません
    </div>
  <% end %>

  <%# Error display %>
  <% if @stripe_error %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-6 text-sm">
      Stripe エラー: <%= @stripe_error %>
    </div>
  <% end %>

  <%# Stripe Connect status %>
  <div class="border border-gray-200 rounded-xl p-5 mb-6">
    <div class="flex items-start gap-4">
      <div class="w-10 h-10 bg-<%= @creator_profile.payout_enabled? ? 'green' : 'gray' %>-100 rounded-xl flex items-center justify-center flex-shrink-0">
        <% if @creator_profile.payout_enabled? %>
          <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        <% else %>
          <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
          </svg>
        <% end %>
      </div>
      <div class="flex-1">
        <p class="font-bold"><%= @creator_profile.payout_enabled? ? "Stripe Connect 設定済み ✓" : "Stripe Connect 未設定" %></p>
        <% if @creator_profile.payout_enabled? %>
          <p class="text-sm text-gray-500 mt-0.5">収益の受け取りが有効です。振込は Stripe のスケジュールに従って行われます。</p>
          <% if @stripe_dashboard_url %>
            <%= link_to "Stripe ダッシュボードを開く →", @stripe_dashboard_url,
                  target: "_blank", rel: "noopener",
                  class: "inline-block mt-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm px-4 py-2 rounded-lg transition-colors" %>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-500 mt-0.5">収益を受け取るには Stripe アカウントの設定が必要です。本人確認と銀行口座の登録が含まれます。</p>
          <%= link_to "Stripe Connect を設定する →", creator_stripe_connect_path,
                class: "inline-block mt-3 bg-purple-600 hover:bg-purple-700 text-white font-bold text-sm px-4 py-2 rounded-lg transition-colors" %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Subscription settings %>
  <div class="border border-gray-200 rounded-xl p-5 mb-6">
    <h2 class="font-bold mb-4">サブスクリプション設定</h2>
    <%= form_with model: @creator_profile, url: creator_update_payout_path, method: :patch, class: "space-y-4" do |f| %>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">月額価格（¥）</label>
        <%= f.number_field :subscription_price, min: 0, step: 100,
              class: "w-40 px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/20 transition" %>
        <p class="text-xs text-gray-400 mt-1">0 に設定するとサブスクリプションは無効になります</p>
      </div>
      <div class="flex items-center gap-3">
        <%= f.check_box :accepting_subscribers,
              class: "w-4 h-4 text-purple-600 border-gray-300 rounded cursor-pointer",
              id: "accepting_subscribers_toggle" %>
        <label for="accepting_subscribers_toggle" class="text-sm font-medium cursor-pointer select-none">
          サブスクリプションを受け付ける
        </label>
      </div>
      <%= f.submit "設定を保存", class: "bg-gray-800 hover:bg-gray-900 text-white font-bold px-6 py-2.5 rounded-full text-sm transition-colors cursor-pointer" %>
    <% end %>
  </div>

  <%# Fee explanation %>
  <div class="bg-gray-50 border border-gray-200 rounded-xl p-5">
    <h2 class="font-bold mb-3">手数料について</h2>
    <div class="space-y-2 text-sm text-gray-600">
      <div class="flex justify-between">
        <span>プラットフォーム手数料（Robin）</span>
        <span class="font-semibold">5%</span>
      </div>
      <div class="flex justify-between">
        <span>Stripe 決済手数料（参考）</span>
        <span class="font-semibold">3.6%</span>
      </div>
      <div class="border-t border-gray-200 pt-2 flex justify-between">
        <span class="font-semibold text-gray-800">クリエイター手取り（目安）</span>
        <span class="font-bold text-green-600">約91%</span>
      </div>
    </div>
    <p class="text-xs text-gray-400 mt-3">※ Stripe 手数料はご利用のプランや国によって異なります。</p>
  </div>
</div>
