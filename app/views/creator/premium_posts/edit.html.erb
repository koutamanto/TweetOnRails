<div class="max-w-2xl mx-auto px-4 py-6">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to creator_posts_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
      </svg>
    <% end %>
    <h1 class="text-xl font-bold">投稿を編集</h1>
    <% if @post.published? %>
      <%= link_to premium_post_path(@post), target: "_blank",
            class: "ml-auto text-sm text-purple-600 hover:underline flex items-center gap-1" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
        公開ページ
      <% end %>
    <% end %>
  </div>
  <%= render "form", post: @post %>
  <div class="mt-4 pt-4 border-t border-gray-100">
    <%= button_to "この投稿を削除", creator_post_path(@post), method: :delete,
          data: { confirm: "本当に削除しますか？この操作は取り消せません。" },
          class: "text-sm text-red-500 hover:text-red-700 hover:underline" %>
  </div>
</div>
