<% if post.errors.any? %>
  <div class="mb-6 bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-700">
    <ul class="space-y-1">
      <% post.errors.full_messages.each do |msg| %>
        <li>・ <%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: post,
      url: post.new_record? ? creator_posts_path : creator_post_path(post),
      class: "space-y-5" do |f| %>
  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-1.5">タイトル <span class="text-red-500">*</span></label>
    <%= f.text_field :title, placeholder: "コンテンツのタイトル",
          class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/20 transition" %>
  </div>

  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-1.5">無料プレビュー <span class="text-gray-400 font-normal">(任意)</span></label>
    <p class="text-xs text-gray-400 mb-2">購読していないユーザーに見せるテキスト。コンテンツの魅力を伝えて購読・購入を促しましょう。</p>
    <%= f.text_area :free_preview, rows: 3,
          placeholder: "例: 今回はプロのイラストレーターが使う配色テクニックを徹底解説します...",
          class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/20 transition resize-none" %>
  </div>

  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-1.5">本文 <span class="text-gray-400 font-normal">(購読者・購入者のみ閲覧可能)</span></label>
    <%= f.text_area :body, rows: 10,
          placeholder: "本文を入力してください...",
          class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/20 transition resize-none" %>
  </div>

  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-1.5">画像・動画</label>
    <%= f.file_field :media, multiple: true, accept: "image/*,video/*",
          class: "w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100 cursor-pointer" %>
    <p class="text-xs text-gray-400 mt-1">1ファイルあたり最大10MB</p>
  </div>

  <div class="border border-gray-200 rounded-xl p-5">
    <label class="block text-sm font-semibold text-gray-700 mb-3">価格設定</label>
    <div class="flex items-center gap-3 mb-3">
      <span class="text-gray-500 font-medium">¥</span>
      <%= f.number_field :price, min: 0, step: 100, placeholder: "0",
            class: "w-36 px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/20 transition" %>
    </div>
    <div class="space-y-1.5 text-xs text-gray-500">
      <p><strong>¥0</strong> → サブスクライバーのみ無料閲覧</p>
      <p><strong>¥1以上</strong> → 個別購入（都度払い）。サブスクライバーも購入が必要です。</p>
    </div>
  </div>

  <div class="flex items-center gap-3 p-4 bg-gray-50 border border-gray-200 rounded-xl">
    <%= f.check_box :published, class: "w-4 h-4 text-purple-600 border-gray-300 rounded focus:ring-purple-500" %>
    <div>
      <label for="premium_post_published" class="font-semibold text-sm cursor-pointer">今すぐ公開する</label>
      <p class="text-xs text-gray-400">チェックを外すとドラフトとして保存されます</p>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit post.new_record? ? "投稿を作成" : "更新する",
          class: "flex-1 bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-full text-sm transition-colors cursor-pointer" %>
    <%= link_to "キャンセル", creator_posts_path,
          class: "px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-full text-sm hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
