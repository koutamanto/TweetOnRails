<div class="max-w-2xl mx-auto px-4 py-10">
  <%# Header %>
  <div class="mb-8 text-center">
    <div class="inline-flex items-center justify-center w-14 h-14 bg-purple-100 rounded-2xl mb-4">
      <svg class="w-7 h-7 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
      </svg>
    </div>
    <% if @creator_profile.persisted? %>
      <h1 class="text-2xl font-bold">クリエイタープロフィールを編集</h1>
    <% else %>
      <h1 class="text-2xl font-bold">クリエイターになる</h1>
      <p class="text-gray-500 mt-2">ファンに向けたプレミアムコンテンツを公開し、収益を得ましょう。Robin は成約ごとに 5% のみ徴収します。</p>
    <% end %>
  </div>

  <% if @creator_profile.errors.any? %>
    <div class="mb-6 bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-700">
      <ul class="space-y-1">
        <% @creator_profile.errors.full_messages.each do |msg| %>
          <li>・ <%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @creator_profile, url: creator_create_account_path, method: :post, class: "space-y-6" do |f| %>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1.5">キャッチコピー <span class="text-gray-400 font-normal">(任意・200文字以内)</span></label>
      <%= f.text_area :tagline, rows: 2,
            placeholder: "例: イラストレーター。毎週メイキング動画と限定イラストを配信中。",
            class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/20 transition resize-none" %>
    </div>

    <div class="border border-gray-200 rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="font-semibold text-gray-800">月額サブスクリプション</p>
          <p class="text-sm text-gray-500 mt-0.5">ファンが毎月支払い、全コンテンツにアクセスできます</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <%= f.check_box :accepting_subscribers, class: "sr-only peer", id: "accepting_subscribers_toggle" %>
          <div class="w-11 h-6 bg-gray-200 peer-focus:ring-2 peer-focus:ring-purple-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-purple-600"></div>
        </label>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-gray-500 font-medium">¥</span>
        <%= f.number_field :subscription_price, min: 0, step: 100,
              placeholder: "500",
              class: "w-40 px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/20 transition" %>
        <span class="text-gray-500 text-sm">/ 月</span>
      </div>
      <p class="text-xs text-gray-400 mt-2">0 に設定すると月額サブスクは無効になります。個別コンテンツの販売は別途設定できます。</p>
    </div>

    <div class="bg-purple-50 border border-purple-100 rounded-xl p-4 text-sm text-purple-700 flex gap-3">
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <p class="font-semibold mb-0.5">Robin の手数料について</p>
        <p>すべての取引に対し、プラットフォーム手数料として <strong>5%</strong> を徴収します。残りの <strong>95%</strong> がお客様の収益になります。Stripe の決済手数料は別途発生します。</p>
      </div>
    </div>

    <div class="flex gap-3">
      <%= f.submit @creator_profile.persisted? ? "保存する" : "クリエイターになる",
            class: "flex-1 bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-full text-sm transition-colors cursor-pointer" %>
      <% if @creator_profile.persisted? %>
        <%= link_to "キャンセル", creator_dashboard_path,
              class: "px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-full text-sm hover:bg-gray-50 transition-colors" %>
      <% end %>
    </div>
  <% end %>

  <% unless @creator_profile.persisted? %>
    <%# Steps preview %>
    <div class="mt-10 border-t border-gray-100 pt-8">
      <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">開始までの流れ</p>
      <div class="space-y-4">
        <div class="flex gap-3">
          <div class="w-7 h-7 rounded-full bg-purple-600 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">1</div>
          <div>
            <p class="font-semibold text-sm">プロフィール設定</p>
            <p class="text-xs text-gray-500">キャッチコピーと価格を設定します</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="w-7 h-7 rounded-full bg-gray-200 text-gray-500 text-xs font-bold flex items-center justify-center flex-shrink-0">2</div>
          <div>
            <p class="font-semibold text-sm">Stripe Connect 設定</p>
            <p class="text-xs text-gray-500">収益受け取りのための口座情報を登録します（Stripe が安全に管理）</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="w-7 h-7 rounded-full bg-gray-200 text-gray-500 text-xs font-bold flex items-center justify-center flex-shrink-0">3</div>
          <div>
            <p class="font-semibold text-sm">コンテンツ公開</p>
            <p class="text-xs text-gray-500">記事・画像・動画などのプレミアムコンテンツを投稿します</p>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
