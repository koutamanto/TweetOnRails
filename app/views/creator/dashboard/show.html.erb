<%# Creator Dashboard %>
<div class="px-4 py-6 max-w-2xl">

  <%# Page title %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold">クリエイターダッシュボード</h1>
      <p class="text-sm text-gray-500 mt-0.5">@<%= current_user.username %></p>
    </div>
    <%= link_to creator_profile_path(current_user.username), target: "_blank",
          class: "text-sm text-purple-600 hover:underline flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
      </svg>
      公開ページを見る
    <% end %>
  </div>

  <%# Stripe Connect banner %>
  <% unless @creator_profile.payout_enabled? %>
    <div class="mb-6 bg-amber-50 border border-amber-200 rounded-xl p-4 flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
      </svg>
      <div class="flex-1">
        <p class="font-semibold text-amber-800 text-sm">収益受け取りの設定が必要です</p>
        <p class="text-xs text-amber-700 mt-0.5">Stripe Connect を設定すると、ファンからの支払いを受け取れるようになります。</p>
      </div>
      <%= link_to "Stripe を設定する →", creator_stripe_connect_path,
            class: "flex-shrink-0 bg-amber-500 hover:bg-amber-600 text-white text-xs font-bold px-3 py-2 rounded-lg transition-colors" %>
    </div>
  <% end %>

  <%# Stats cards %>
  <div class="grid grid-cols-3 gap-3 mb-6">
    <div class="bg-purple-50 border border-purple-100 rounded-xl p-4 text-center">
      <p class="text-2xl font-extrabold text-purple-700"><%= @subscriber_count %></p>
      <p class="text-xs text-purple-500 mt-0.5">サブスクライバー</p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-center">
      <p class="text-2xl font-extrabold text-gray-800"><%= @published_count %></p>
      <p class="text-xs text-gray-500 mt-0.5">公開中の投稿</p>
    </div>
    <div class="bg-green-50 border border-green-100 rounded-xl p-4 text-center">
      <p class="text-2xl font-extrabold text-green-700">¥<%= number_with_delimiter(@total_earned) %></p>
      <p class="text-xs text-green-500 mt-0.5">累計収益</p>
    </div>
  </div>

  <%# Quick actions %>
  <div class="grid grid-cols-2 gap-3 mb-6">
    <%= link_to new_creator_post_path,
          class: "flex items-center gap-3 p-4 border border-gray-200 rounded-xl hover:border-purple-300 hover:bg-purple-50 transition-colors group" do %>
      <div class="w-9 h-9 bg-purple-100 rounded-lg flex items-center justify-center group-hover:bg-purple-200 transition-colors">
        <svg class="w-5 h-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
        </svg>
      </div>
      <div>
        <p class="font-semibold text-sm">投稿を作成</p>
        <p class="text-xs text-gray-400">新しいコンテンツを追加</p>
      </div>
    <% end %>
    <%= link_to creator_earnings_path,
          class: "flex items-center gap-3 p-4 border border-gray-200 rounded-xl hover:border-green-300 hover:bg-green-50 transition-colors group" do %>
      <div class="w-9 h-9 bg-green-100 rounded-lg flex items-center justify-center group-hover:bg-green-200 transition-colors">
        <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/>
        </svg>
      </div>
      <div>
        <p class="font-semibold text-sm">収益・明細</p>
        <p class="text-xs text-gray-400">収益の詳細を確認</p>
      </div>
    <% end %>
    <%= link_to creator_posts_path,
          class: "flex items-center gap-3 p-4 border border-gray-200 rounded-xl hover:border-blue-300 hover:bg-blue-50 transition-colors group" do %>
      <div class="w-9 h-9 bg-blue-100 rounded-lg flex items-center justify-center group-hover:bg-blue-200 transition-colors">
        <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"/>
        </svg>
      </div>
      <div>
        <p class="font-semibold text-sm">投稿管理</p>
        <p class="text-xs text-gray-400">投稿の編集・削除</p>
      </div>
    <% end %>
    <%= link_to creator_payout_path,
          class: "flex items-center gap-3 p-4 border border-gray-200 rounded-xl hover:border-gray-300 hover:bg-gray-50 transition-colors group" do %>
      <div class="w-9 h-9 bg-gray-100 rounded-lg flex items-center justify-center group-hover:bg-gray-200 transition-colors">
        <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <div>
        <p class="font-semibold text-sm">支払い設定</p>
        <p class="text-xs text-gray-400">Stripe・振込先管理</p>
      </div>
    <% end %>
  </div>

  <%# Recent posts %>
  <% if @recent_posts.any? %>
    <div class="mb-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-bold text-gray-800">最近の投稿</h2>
        <%= link_to "すべて見る", creator_posts_path, class: "text-sm text-purple-600 hover:underline" %>
      </div>
      <div class="space-y-2">
        <% @recent_posts.each do |post| %>
          <div class="flex items-center gap-3 p-3 border border-gray-100 rounded-xl hover:bg-gray-50 transition-colors">
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-sm truncate"><%= post.title %></p>
              <p class="text-xs text-gray-400 mt-0.5">
                <%= post.published_at&.strftime("%m/%d") %>
                · 閲覧 <%= post.views_count %>
                <% if post.ppv? %>
                  · <span class="text-purple-600">¥<%= number_with_delimiter(post.price) %></span>
                <% else %>
                  · <span class="text-blue-500">サブスク限定</span>
                <% end %>
              </p>
            </div>
            <%= link_to "編集", edit_creator_post_path(post),
                  class: "text-xs text-gray-500 hover:text-gray-700 px-2 py-1 rounded-lg hover:bg-gray-200 transition-colors flex-shrink-0" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Recent subscribers %>
  <% if @recent_subscribers.any? %>
    <div>
      <h2 class="font-bold text-gray-800 mb-3">最近のサブスクライバー</h2>
      <div class="space-y-2">
        <% @recent_subscribers.each do |sub| %>
          <div class="flex items-center gap-3 p-3 border border-gray-100 rounded-xl">
            <%= avatar_tag(sub.subscriber, size: :sm) %>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-sm truncate"><%= sub.subscriber.display_name %></p>
              <p class="text-xs text-gray-400">@<%= sub.subscriber.username %> · <%= sub.created_at.strftime("%m/%d") %>から</p>
            </div>
            <span class="text-xs text-green-600 font-semibold">¥<%= number_with_delimiter(sub.amount_paid) %>/月</span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @recent_posts.empty? && @draft_posts.empty? %>
    <div class="text-center py-12 border-2 border-dashed border-gray-200 rounded-2xl">
      <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
      </svg>
      <p class="font-semibold text-gray-500 mb-1">まだ投稿がありません</p>
      <p class="text-sm text-gray-400 mb-4">最初のプレミアムコンテンツを作成しましょう</p>
      <%= link_to "投稿を作成する", new_creator_post_path,
            class: "bg-purple-600 hover:bg-purple-700 text-white font-bold px-6 py-2.5 rounded-full text-sm transition-colors" %>
    </div>
  <% end %>
</div>
