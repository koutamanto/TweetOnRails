<div class="px-4 py-6 max-w-2xl">
  <h1 class="text-xl font-bold mb-6">収益・明細</h1>

  <%# Summary cards %>
  <div class="grid grid-cols-3 gap-3 mb-8">
    <div class="bg-green-50 border border-green-100 rounded-xl p-4">
      <p class="text-xs text-green-500 font-semibold uppercase tracking-wide mb-1">累計収益</p>
      <p class="text-2xl font-extrabold text-green-700">¥<%= number_with_delimiter(@total_earned) %></p>
      <p class="text-xs text-green-500 mt-0.5">プラットフォーム手数料控除後</p>
    </div>
    <div class="bg-purple-50 border border-purple-100 rounded-xl p-4">
      <p class="text-xs text-purple-500 font-semibold uppercase tracking-wide mb-1">サブスクライバー</p>
      <p class="text-2xl font-extrabold text-purple-700"><%= @subscriber_count %></p>
      <p class="text-xs text-purple-500 mt-0.5">現在のアクティブ数</p>
    </div>
    <div class="bg-blue-50 border border-blue-100 rounded-xl p-4">
      <p class="text-xs text-blue-500 font-semibold uppercase tracking-wide mb-1">月次収益(見込)</p>
      <p class="text-2xl font-extrabold text-blue-700">¥<%= number_with_delimiter((@monthly_revenue * 0.95).to_i) %></p>
      <p class="text-xs text-blue-500 mt-0.5">手数料5%控除後</p>
    </div>
  </div>

  <%# Payout link %>
  <div class="mb-6 p-4 border border-gray-200 rounded-xl flex items-center gap-3">
    <svg class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
    </svg>
    <div class="flex-1">
      <p class="font-semibold text-sm">振込・支払い設定</p>
      <p class="text-xs text-gray-400">Stripe ダッシュボードで振込先や支払いスケジュールを確認・設定できます</p>
    </div>
    <%= link_to "Stripe を開く →", creator_payout_path,
          class: "text-sm text-purple-600 font-semibold hover:underline flex-shrink-0" %>
  </div>

  <%# Subscriber list %>
  <% if @fan_subscriptions.any? %>
    <div class="mb-8">
      <h2 class="font-bold text-gray-800 mb-3">サブスクライバー一覧</h2>
      <div class="border border-gray-200 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-semibold text-gray-500 text-xs">ユーザー</th>
              <th class="text-right px-4 py-3 font-semibold text-gray-500 text-xs">月額</th>
              <th class="text-right px-4 py-3 font-semibold text-gray-500 text-xs">開始日</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @fan_subscriptions.each do |sub| %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <%= avatar_tag(sub.subscriber, size: :xs) %>
                    <div>
                      <p class="font-semibold"><%= sub.subscriber.display_name %></p>
                      <p class="text-xs text-gray-400">@<%= sub.subscriber.username %></p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3 text-right font-semibold text-green-600">¥<%= number_with_delimiter((sub.amount_paid * 0.95).to_i) %></td>
                <td class="px-4 py-3 text-right text-gray-400 text-xs"><%= sub.created_at.strftime("%Y/%m/%d") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# Purchase history %>
  <% if @recent_purchases.any? %>
    <div>
      <h2 class="font-bold text-gray-800 mb-3">個別購入履歴</h2>
      <div class="border border-gray-200 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-semibold text-gray-500 text-xs">コンテンツ</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-500 text-xs">購入者</th>
              <th class="text-right px-4 py-3 font-semibold text-gray-500 text-xs">収益</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @recent_purchases.each do |purchase| %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3">
                  <p class="font-semibold truncate max-w-[160px]"><%= purchase.premium_post.title %></p>
                  <p class="text-xs text-gray-400"><%= purchase.created_at.strftime("%m/%d") %></p>
                </td>
                <td class="px-4 py-3">
                  <p class="text-sm">@<%= purchase.buyer.username %></p>
                </td>
                <td class="px-4 py-3 text-right font-semibold text-green-600">¥<%= number_with_delimiter(purchase.creator_earned) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if @fan_subscriptions.empty? && @recent_purchases.empty? %>
    <div class="text-center py-12 border-2 border-dashed border-gray-200 rounded-2xl">
      <p class="font-semibold text-gray-400 mb-1">まだ収益がありません</p>
      <p class="text-sm text-gray-400">コンテンツを公開してファンを増やしましょう</p>
    </div>
  <% end %>
</div>
