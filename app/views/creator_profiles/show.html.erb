<% content_for :seo_title, "#{@creator.display_name} — クリエイターページ" %>
<% desc_parts = [@creator_profile.tagline.presence, @creator.bio.presence, "#{@subscriber_count}人がサポート · #{@posts.count}件の投稿"].compact %>
<% content_for :seo_desc, desc_parts.join(" — ").truncate(160) %>
<% content_for :seo_image, absolute_avatar_url(@creator) %>
<% content_for :seo_canonical, "https://robin.katskouta.one/creators/#{@creator.username}" %>
<% content_for :structured_data do %>
<%= breadcrumb_json_ld([
  {name: "ホーム", url: "https://robin.katskouta.one/"},
  {name: "クリエイター", url: "https://robin.katskouta.one/explore"},
  {name: @creator.display_name, url: "https://robin.katskouta.one/creators/#{@creator.username}"}
]) %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": <%= @creator.display_name.to_json.html_safe %>,
    "alternateName": "@<%= @creator.username %>",
    "url": "https://robin.katskouta.one/creators/<%= @creator.username %>",
    "image": "<%= absolute_avatar_url(@creator) %>",
    "description": <%= (@creator_profile.tagline.presence || @creator.bio.to_s).to_json.html_safe %>,
    "interactionStatistic": [
      {"@type":"InteractionCounter","interactionType":"https://schema.org/SubscribeAction","userInteractionCount":<%= @subscriber_count %>}
    ]
  }
  <% if @creator_profile.has_subscription_plan? %>,
  "offers": {
    "@type": "Offer",
    "name": <%= "#{@creator.display_name} サブスクリプション".to_json.html_safe %>,
    "price": "<%= @creator_profile.subscription_price %>",
    "priceCurrency": "JPY",
    "priceSpecification": {"@type":"RecurringChargeSpecification","billingDuration":"P1M"},
    "url": "https://robin.katskouta.one/creators/<%= @creator.username %>"
  }
  <% end %>
}
</script>
<% end %>

<%# Creator public profile page %>
<div>
  <%# Cover image / gradient header %>
  <div class="h-36 bg-gradient-to-br from-purple-600 via-violet-500 to-indigo-600 relative">
    <% if @creator_profile.cover_image.attached? %>
      <%= image_tag @creator_profile.cover_image, class: "w-full h-full object-cover" %>
    <% end %>
  </div>

  <%# Profile header %>
  <div class="px-4 pb-4 border-b border-gray-100">
    <div class="flex items-end justify-between -mt-10 mb-3">
      <%= avatar_tag(@creator, size: :xl) %>
      <div class="flex gap-2 pb-2">
        <% if user_signed_in? && current_user == @creator %>
          <%= link_to creator_dashboard_path, class: "flex items-center gap-1.5 border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold text-sm px-4 py-1.5 rounded-full transition-colors" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"/>
            </svg>
            ダッシュボード
          <% end %>
        <% elsif @creator_profile.has_subscription_plan? %>
          <% if @is_subscribed %>
            <span class="flex items-center gap-1.5 bg-purple-50 text-purple-700 border border-purple-200 font-semibold text-sm px-4 py-1.5 rounded-full">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              サブスク中
            </span>
            <% if @my_subscription&.active? && @my_subscription&.stripe_subscription_id.present? %>
              <%= button_to "解約", fan_subscription_path(@my_subscription), method: :delete,
                    data: { confirm: "サブスクリプションをキャンセルしてもよいですか？" },
                    class: "text-xs text-gray-400 hover:text-gray-600 border border-gray-200 hover:bg-gray-50 px-3 py-1.5 rounded-full transition-colors" %>
            <% end %>
          <% elsif user_signed_in? %>
            <%= form_with url: fan_subscriptions_path, method: :post, data: { turbo: false } do |f| %>
              <%= f.hidden_field :creator_profile_id, value: @creator_profile.id %>
              <%= f.submit "¥#{number_with_delimiter(@creator_profile.subscription_price)}/月 サポートする",
                    class: "bg-purple-600 hover:bg-purple-700 text-white font-bold text-sm px-5 py-1.5 rounded-full transition-colors cursor-pointer" %>
            <% end %>
          <% else %>
            <%= link_to "¥#{number_with_delimiter(@creator_profile.subscription_price)}/月 サポートする",
                  new_user_session_path,
                  class: "bg-purple-600 hover:bg-purple-700 text-white font-bold text-sm px-5 py-1.5 rounded-full transition-colors" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-2 mb-0.5">
      <h1 class="text-xl font-bold"><%= @creator.display_name %></h1>
      <%= render "shared/pro_badge", user: @creator %>
      <span class="inline-flex items-center gap-1 bg-purple-100 text-purple-700 text-xs font-semibold px-2 py-0.5 rounded-full">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
        クリエイター
      </span>
    </div>
    <p class="text-gray-500 text-sm mb-2">@<%= @creator.username %></p>
    <% if @creator_profile.tagline.present? %>
      <p class="text-gray-700 text-sm mb-3"><%= @creator_profile.tagline %></p>
    <% end %>
    <div class="flex gap-4 text-sm">
      <span><strong><%= @subscriber_count %></strong> <span class="text-gray-500">サブスクライバー</span></span>
      <span><strong><%= @posts.count %></strong> <span class="text-gray-500">投稿</span></span>
    </div>
  </div>

  <%# Posts list %>
  <% if @posts.any? %>
    <div class="divide-y divide-gray-100">
      <% @posts.each do |post| %>
        <% can_access = post.accessible_by?(current_user) %>
        <%= link_to premium_post_path(post), class: "block px-4 py-4 hover:bg-gray-50 transition-colors" do %>
          <div class="flex items-start gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <% if post.ppv? %>
                  <span class="text-xs font-bold bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full">
                    ¥<%= number_with_delimiter(post.price) %>
                  </span>
                <% else %>
                  <span class="text-xs font-bold bg-blue-50 text-blue-600 px-2 py-0.5 rounded-full">サブスク限定</span>
                <% end %>
                <% if can_access %>
                  <span class="text-xs text-green-500 font-medium">✓ 閲覧可能</span>
                <% end %>
              </div>
              <h3 class="font-bold text-gray-900 mb-1 leading-snug"><%= post.title %></h3>
              <% if post.free_preview.present? %>
                <p class="text-sm text-gray-500 line-clamp-2"><%= post.free_preview %></p>
              <% end %>
              <p class="text-xs text-gray-400 mt-2"><%= post.published_at&.strftime("%Y年%m月%d日") %></p>
            </div>
            <% unless can_access %>
              <svg class="w-5 h-5 text-gray-300 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <p class="text-gray-400">まだ投稿がありません</p>
    </div>
  <% end %>
</div>
