<!DOCTYPE html>
<html lang="ja">
  <head>
    <title>Robin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% unless user_signed_in? %>
      <meta name="turbo-cache-control" content="no-cache">
    <% end %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-gray-900 antialiased">
    <% if user_signed_in? %>
      <div class="flex min-h-screen max-w-7xl mx-auto">
        <%# Left Sidebar %>
        <aside class="hidden md:flex flex-col sticky top-0 h-screen w-[72px] xl:w-[275px] flex-shrink-0 px-2 xl:px-4 pt-1 border-r border-gray-100">
          <%= link_to root_path, class: "p-3 rounded-full hover:bg-gray-100 transition-colors w-fit mb-1" do %>
            <%= render "shared/robin_logo", size_class: "w-7 h-7", color_class: "text-sky-500" %>
          <% end %>

          <nav class="flex flex-col gap-0.5">
            <%= link_to root_path, class: "flex items-center gap-4 px-3 py-3 rounded-full hover:bg-gray-100 transition-colors group w-fit xl:w-full #{current_page?(root_path) ? 'font-bold' : ''}" do %>
              <svg class="w-[26px] h-[26px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="<%= current_page?(root_path) ? 2.5 : 2 %>">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
              </svg>
              <span class="text-xl hidden xl:block">ホーム</span>
            <% end %>

            <%= link_to explore_path, class: "flex items-center gap-4 px-3 py-3 rounded-full hover:bg-gray-100 transition-colors group w-fit xl:w-full #{current_page?(explore_path) ? 'font-bold' : ''}" do %>
              <svg class="w-[26px] h-[26px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="<%= current_page?(explore_path) ? 2.5 : 2 %>">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z"/>
              </svg>
              <span class="text-xl hidden xl:block">探す</span>
            <% end %>

            <%= link_to notifications_path, class: "flex items-center gap-4 px-3 py-3 rounded-full hover:bg-gray-100 transition-colors group w-fit xl:w-full #{current_page?(notifications_path) ? 'font-bold' : ''}" do %>
              <span class="relative">
                <svg class="w-[26px] h-[26px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="<%= current_page?(notifications_path) ? 2.5 : 2 %>">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
                </svg>
                <% if @unread_notifications_count.to_i > 0 %>
                  <span class="absolute -top-1 -right-1 bg-sky-500 text-white text-[10px] rounded-full min-w-[16px] h-4 flex items-center justify-center px-0.5"><%= @unread_notifications_count > 99 ? "99+" : @unread_notifications_count %></span>
                <% end %>
              </span>
              <span class="text-xl hidden xl:block">通知</span>
            <% end %>

            <%= link_to conversations_path, class: "flex items-center gap-4 px-3 py-3 rounded-full hover:bg-gray-100 transition-colors group w-fit xl:w-full #{current_page?(conversations_path) ? 'font-bold' : ''}" do %>
              <span class="relative">
                <svg class="w-[26px] h-[26px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="<%= current_page?(conversations_path) ? 2.5 : 2 %>">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                </svg>
                <% if @unread_messages_count.to_i > 0 %>
                  <span class="absolute -top-1 -right-1 bg-sky-500 text-white text-[10px] rounded-full min-w-[16px] h-4 flex items-center justify-center px-0.5"><%= @unread_messages_count > 99 ? "99+" : @unread_messages_count %></span>
                <% end %>
              </span>
              <span class="text-xl hidden xl:block">メッセージ</span>
            <% end %>

            <%= link_to bookmarks_path, class: "flex items-center gap-4 px-3 py-3 rounded-full hover:bg-gray-100 transition-colors group w-fit xl:w-full #{current_page?(bookmarks_path) ? 'font-bold' : ''}" do %>
              <svg class="w-[26px] h-[26px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="<%= current_page?(bookmarks_path) ? 2.5 : 2 %>">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z"/>
              </svg>
              <span class="text-xl hidden xl:block">ブックマーク</span>
            <% end %>

            <%# Creator hub %>
            <% creator_active = controller_path.start_with?("creator") %>
            <%= link_to current_user.creator_profile ? creator_dashboard_path : creator_setup_path,
                  class: "flex items-center gap-4 px-3 py-3 rounded-full hover:bg-gray-100 transition-colors group w-fit xl:w-full #{creator_active ? 'font-bold' : ''}" do %>
              <svg class="w-[26px] h-[26px] <%= creator_active ? 'text-purple-600' : '' %>" fill="<%= creator_active ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="<%= creator_active ? 'none' : 'currentColor' %>" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
              </svg>
              <span class="text-xl hidden xl:block <%= creator_active ? 'text-purple-600' : '' %>">クリエイター</span>
            <% end %>

            <%= link_to user_path(current_user.username), class: "flex items-center gap-4 px-3 py-3 rounded-full hover:bg-gray-100 transition-colors group w-fit xl:w-full" do %>
              <svg class="w-[26px] h-[26px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
              </svg>
              <span class="text-xl hidden xl:block">プロフィール</span>
            <% end %>

            <%= link_to settings_profile_path, class: "flex items-center gap-4 px-3 py-3 rounded-full hover:bg-gray-100 transition-colors group w-fit xl:w-full" do %>
              <svg class="w-[26px] h-[26px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-xl hidden xl:block">設定</span>
            <% end %>
          </nav>

          <%# Upgrade CTA — shown only for free users %>
          <% unless current_user.pro? %>
            <%= link_to pricing_path, class: "mt-3 hidden xl:flex items-center gap-2 border border-amber-400 text-amber-600 hover:bg-amber-50 font-semibold rounded-full px-4 py-2 text-sm transition-colors w-fit xl:w-full" do %>
              <svg class="w-4 h-4 text-amber-400 flex-shrink-0" viewBox="0 0 24 24">
                <path fill="currentColor" d="M12 2L3 6.5V12c0 5.25 3.83 9.54 9 10.93C17.17 21.54 21 17.25 21 12V6.5L12 2Z"/>
                <path fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M8.5 12l2.5 2.5 4.5-5"/>
              </svg>
              <span>Pro にアップグレード</span>
            <% end %>
          <% end %>

          <%# Tweet button %>
          <%= link_to root_path, data: { turbo_frame: "tweet_form_modal" }, class: "mt-3 bg-sky-500 hover:bg-sky-600 text-white font-bold rounded-full transition-colors px-5 py-3 w-fit xl:w-full text-center hidden xl:block" do %>
            ツイートする
          <% end %>
          <%= link_to root_path, class: "mt-4 bg-sky-500 hover:bg-sky-600 text-white font-bold rounded-full p-3 w-fit xl:hidden" do %>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
            </svg>
          <% end %>

          <%# User menu at bottom %>
          <div class="mt-auto mb-3">
            <%= link_to "#", data: { controller: "dropdown" }, class: "flex items-center gap-3 px-3 py-3 rounded-full hover:bg-gray-100 transition-colors w-full" do %>
              <div class="flex-shrink-0"><%= avatar_tag(current_user, size: :sm) %></div>
              <div class="hidden xl:block min-w-0 flex-1">
                <p class="font-bold text-sm truncate flex items-center gap-1">
                  <%= current_user.display_name %>
                  <%= render "shared/pro_badge", user: current_user %>
                </p>
                <p class="text-gray-500 text-sm truncate">@<%= current_user.username %></p>
              </div>
              <svg class="w-5 h-5 text-gray-500 hidden xl:block flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 12a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM12.75 12a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM18.75 12a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
              </svg>
            <% end %>
            <%= button_to destroy_user_session_path, method: :delete, class: "w-full text-left text-sm text-red-500 hover:bg-red-50 px-3 py-2 rounded-lg transition-colors mt-1" do %>
              ログアウト
            <% end %>
          </div>
        </aside>

        <%# Main Content %>
        <main class="flex-1 min-w-0 max-w-[600px] border-r border-gray-100">
          <% if notice.present? %>
            <div class="bg-sky-50 border-b border-sky-100 text-sky-800 text-sm px-4 py-3"><%= notice %></div>
          <% end %>
          <% if alert.present? %>
            <div class="bg-red-50 border-b border-red-100 text-red-800 text-sm px-4 py-3"><%= alert %></div>
          <% end %>
          <%= yield %>
        </main>

        <%# Right Sidebar %>
        <aside class="hidden lg:block w-[350px] flex-shrink-0 pl-8 pt-4 sticky top-0 h-screen overflow-y-auto">
          <%# Search %>
          <%= form_with url: search_path, method: :get, local: true, class: "mb-4" do |f| %>
            <div class="relative">
              <svg class="absolute left-3 top-2.5 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z"/>
              </svg>
              <%= f.search_field :q, placeholder: "検索", value: params[:q], class: "w-full pl-10 pr-4 py-2.5 bg-gray-100 hover:bg-gray-200 focus:bg-white rounded-full text-sm border border-transparent focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 focus:outline-none transition" %>
            </div>
          <% end %>

          <%# Who to follow %>
          <% suggested = User.where.not(id: current_user.id).where.not(id: current_user.following).limit(3) %>
          <% if suggested.any? %>
            <div class="bg-gray-50 rounded-2xl p-4 mb-4">
              <h2 class="font-bold text-xl mb-3">おすすめユーザー</h2>
              <% suggested.each do |user| %>
                <div class="flex items-center gap-3 py-2">
                  <%= link_to user_path(user.username), class: "flex-shrink-0" do %>
                    <%= avatar_tag(user, size: :sm) %>
                  <% end %>
                  <div class="flex-1 min-w-0">
                    <%= link_to user.display_name, user_path(user.username), class: "font-bold text-sm hover:underline truncate block" %>
                    <p class="text-gray-500 text-xs truncate">@<%= user.username %></p>
                  </div>
                  <%= render "users/follow_btn", user: user, current_user: current_user %>
                </div>
              <% end %>
            </div>
          <% end %>
        </aside>
      </div>

      <%# Mobile bottom nav %>
      <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-100 flex md:hidden z-50">
        <%= link_to root_path, class: "flex-1 flex flex-col items-center py-2 #{current_page?(root_path) ? 'text-sky-500' : 'text-gray-500'}" do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
          </svg>
        <% end %>
        <%= link_to explore_path, class: "flex-1 flex flex-col items-center py-2 #{current_page?(explore_path) ? 'text-sky-500' : 'text-gray-500'}" do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z"/>
          </svg>
        <% end %>
        <%= link_to notifications_path, class: "flex-1 flex flex-col items-center py-2 relative #{current_page?(notifications_path) ? 'text-sky-500' : 'text-gray-500'}" do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
          </svg>
          <% if @unread_notifications_count.to_i > 0 %>
            <span class="absolute top-1 right-6 bg-sky-500 w-2 h-2 rounded-full"></span>
          <% end %>
        <% end %>
        <%= link_to conversations_path, class: "flex-1 flex flex-col items-center py-2 #{current_page?(conversations_path) ? 'text-sky-500' : 'text-gray-500'}" do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
        <% end %>
        <%= link_to user_path(current_user.username), class: "flex-1 flex flex-col items-center py-2 #{controller_name == 'users' ? 'text-sky-500' : 'text-gray-500'}" do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
          </svg>
        <% end %>
      </nav>
      <div class="h-14 md:hidden"></div>

    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>
