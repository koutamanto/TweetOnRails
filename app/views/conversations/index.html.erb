<div class="sticky top-0 bg-white/80 backdrop-blur-sm border-b border-gray-100 px-4 py-3 z-10 flex items-center justify-between">
  <h1 class="font-bold text-xl">メッセージ</h1>
  <button class="p-2 rounded-full hover:bg-gray-100 transition-colors text-gray-600" title="新しいメッセージ">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/>
    </svg>
  </button>
</div>

<% if @conversations.any? %>
  <% @conversations.each do |conversation| %>
    <% other = conversation.other_participant(current_user) %>
    <% next unless other %>
    <%= link_to conversation_path(conversation), class: "flex items-center gap-3 px-4 py-4 hover:bg-gray-50 border-b border-gray-100 transition-colors" do %>
      <%= avatar_tag(other, size: :md) %>
      <div class="flex-1 min-w-0">
        <div class="flex items-center justify-between">
          <span class="font-bold text-sm truncate flex items-center gap-1"><%= other.display_name %><%= render "shared/pro_badge", user: other %></span>
          <% if (lm = conversation.last_message) %>
            <span class="text-xs text-gray-400"><%= relative_time(lm.created_at) %></span>
          <% end %>
        </div>
        <p class="text-gray-500 text-xs truncate">@<%= other.username %></p>
        <% if (lm = conversation.last_message) %>
          <p class="text-sm text-gray-600 truncate mt-0.5"><%= lm.body %></p>
        <% end %>
      </div>
      <% unread = conversation.unread_count_for(current_user) %>
      <% if unread > 0 %>
        <span class="bg-sky-500 text-white text-xs rounded-full min-w-[20px] h-5 flex items-center justify-center px-1"><%= unread %></span>
      <% end %>
    <% end %>
  <% end %>
<% else %>
  <div class="text-center py-16 px-4">
    <div class="w-16 h-16 bg-sky-50 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
      </svg>
    </div>
    <h2 class="font-bold text-2xl mb-2">メッセージがありません</h2>
    <p class="text-gray-500 text-sm">ユーザーのプロフィールページからメッセージを送りましょう</p>
  </div>
<% end %>
