<% other = @conversation.other_participant(current_user) %>

<div class="sticky top-0 bg-white/80 backdrop-blur-sm border-b border-gray-100 px-4 py-3 z-10 flex items-center gap-3">
  <%= link_to conversations_path, class: "p-2 rounded-full hover:bg-gray-100 transition-colors -ml-2 flex-shrink-0" do %>
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
  <% end %>
  <% if other %>
    <%= link_to user_path(other.username), class: "flex items-center gap-2 hover:opacity-80 transition-opacity" do %>
      <%= avatar_tag(other, size: :sm) %>
      <div>
        <p class="font-bold text-sm leading-tight flex items-center gap-1"><%= other.display_name %><%= render "shared/pro_badge", user: other %></p>
        <p class="text-xs text-gray-500">@<%= other.username %></p>
      </div>
    <% end %>
  <% end %>
</div>

<div class="flex flex-col h-[calc(100vh-120px)]"
     data-controller="conversation"
     data-conversation-conversation-id-value="<%= @conversation.id %>">

  <div id="messages_list" class="flex-1 overflow-y-auto p-4 space-y-3" data-conversation-target="messages">
    <% @messages.each do |message| %>
      <%= render "messages/message", message: message, current_user: current_user %>
    <% end %>
  </div>

  <div class="border-t border-gray-100 p-4 bg-white">
    <%= form_with model: [@conversation, @message], data: { turbo_stream: true, action: "submit->conversation#clearInput" }, class: "flex gap-3 items-end" do |f| %>
      <div class="flex-1">
        <%= f.text_area :body, placeholder: "メッセージを入力...", rows: 1,
              class: "w-full px-4 py-2.5 bg-gray-100 rounded-full text-sm resize-none outline-none focus:ring-2 focus:ring-sky-500/20 focus:bg-white transition",
              data: { conversation_target: "input", action: "keydown->conversation#submitOnEnter" } %>
      </div>
      <%= f.submit "送信", class: "bg-sky-500 hover:bg-sky-600 text-white font-bold px-5 py-2.5 rounded-full text-sm transition-colors cursor-pointer flex-shrink-0" %>
    <% end %>
  </div>
</div>
