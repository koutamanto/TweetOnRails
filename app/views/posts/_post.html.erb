<div id="<%= dom_id post %>" class="bg-white border border-gray-200 rounded-xl p-5 hover:shadow-lg hover:border-indigo-300 transition-all duration-200 group">
  <div class="flex items-start justify-between gap-3 mb-3">
    <h2 class="text-lg font-bold text-gray-900 leading-snug flex-1 group-hover:text-indigo-600 transition-colors">
      <%= link_to post.title, post %>
    </h2>
    <div class="opacity-0 group-hover:opacity-100 transition-opacity">
      <%= render DropdownComponent.new(id: "dropdown-#{post.id}", position: :right) do %>
        <%= link_to "編集", edit_post_path(post), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
        <%= link_to "削除", post, data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "block px-4 py-2 text-sm text-red-600 hover:bg-red-50" %>
      <% end %>
    </div>
  </div>

  <p class="text-gray-600 text-sm leading-relaxed line-clamp-3 mb-3">
    <%= post.content %>
  </p>

  <div class="flex items-center justify-between gap-2 text-xs text-gray-500 pt-2 border-t border-gray-100">
    <div class="flex items-center gap-3">
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M6 6a2 2 0 11-4 0 2 2 0 014 0zM13 6a2 2 0 11-4 0 2 2 0 014 0zM18 6a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        <%= post.comments_count || 0 %>
      </span>
      <span title="<%= formatted_date(post.created_at) %>">
        <%= relative_time(post.created_at) %>
      </span>
    </div>
    <span class="px-2 py-0.5 bg-gray-100 rounded text-gray-600">#<%= post.id %></span>
  </div>
</div>
