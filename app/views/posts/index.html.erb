<div class="mb-6">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">投稿一覧</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= @posts.total_count %> 件の投稿</p>
    </div>
    <%= link_to new_post_path, class: "inline-flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors shadow-sm" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
      </svg>
      新規投稿
    <% end %>
  </div>

  <!-- Search and Filter Bar -->
  <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
    <%= form_with url: posts_path, method: :get, local: true, class: "flex-1 flex gap-2" do |f| %>
      <div class="relative flex-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-2.5 w-5 h-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
        </svg>
        <%= f.search_field :q, placeholder: "タイトル、内容を検索...", value: params[:q], class: "w-full pl-10 pr-4 py-2 rounded-lg border border-gray-300 bg-white text-sm placeholder-gray-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition" %>
      </div>

      <select name="sort" class="px-3 py-2 rounded-lg border border-gray-300 bg-white text-sm text-gray-700 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition">
        <option value="">最新順</option>
        <option value="oldest" <%= 'selected' if params[:sort] == 'oldest' %>>古い順</option>
      </select>

      <%= f.submit "検索", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm cursor-pointer" %>
    <% end %>
  </div>
</div>

<% if @posts.any? %>
  <div id="posts" class="flex flex-col gap-3 mb-8">
    <% @posts.each do |post| %>
      <%= render post %>
    <% end %>
  </div>

  <!-- Pagination -->
  <div class="flex items-center justify-between gap-4">
    <div class="text-sm text-gray-500">
      <span class="font-medium"><%= (@posts.current_page - 1) * @posts.limit_value + 1 %></span>
      <span>-</span>
      <span class="font-medium"><%= [@posts.current_page * @posts.limit_value, @posts.total_count].min %></span>
      <span>件を表示 (全</span>
      <span class="font-medium"><%= @posts.total_count %></span>
      <span>件)</span>
    </div>

    <nav class="flex items-center gap-2">
      <% if @posts.first_page? %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-400 bg-gray-100 border border-gray-300 rounded-lg cursor-not-allowed">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          前へ
        </span>
      <% else %>
        <%= link_to posts_path(page: @posts.current_page - 1, q: params[:q], sort: params[:sort]), class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-600 hover:text-gray-900 bg-white border border-gray-300 hover:border-gray-400 rounded-lg transition-all" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          前へ
        <% end %>
      <% end %>

      <span class="text-gray-600 text-sm font-medium">
        ページ <%= @posts.current_page %> / <%= @posts.total_pages %>
      </span>

      <% if @posts.last_page? %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-400 bg-gray-100 border border-gray-300 rounded-lg cursor-not-allowed">
          次へ
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
          </svg>
        </span>
      <% else %>
        <%= link_to posts_path(page: @posts.current_page + 1, q: params[:q], sort: params[:sort]), class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-600 hover:text-gray-900 bg-white border border-gray-300 hover:border-gray-400 rounded-lg transition-all" do %>
          次へ
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
          </svg>
        <% end %>
      <% end %>
    </nav>
  </div>
<% else %>
  <div class="text-center py-20 text-gray-400">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    <% if params[:q].present? %>
      <p class="text-lg font-medium">検索結果が見つかりません</p>
      <p class="text-sm mt-1">別の検索条件をお試しください</p>
    <% else %>
      <p class="text-lg font-medium">まだ投稿がありません</p>
      <p class="text-sm mt-1">最初の投稿を作成しましょう</p>
    <% end %>
  </div>
<% end %>
