<%# Individual premium post view %>
<div class="max-w-2xl">
  <%# Breadcrumb %>
  <div class="px-4 py-3 border-b border-gray-100 flex items-center gap-2 text-sm text-gray-500">
    <%= link_to @creator.display_name, creator_profile_path(@creator.username), class: "hover:underline" %>
    <span>›</span>
    <span class="text-gray-400 truncate"><%= @post.title %></span>
  </div>

  <article class="px-4 py-6">
    <%# Post header %>
    <div class="mb-5">
      <%# Post type badge %>
      <div class="flex items-center gap-2 mb-3">
        <% if @post.ppv? %>
          <span class="inline-flex items-center gap-1 bg-purple-100 text-purple-700 text-xs font-bold px-2.5 py-1 rounded-full">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
            有料コンテンツ ¥<%= number_with_delimiter(@post.price) %>
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1 bg-blue-50 text-blue-600 text-xs font-bold px-2.5 py-1 rounded-full">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            サブスクライバー限定
          </span>
        <% end %>
      </div>

      <h1 class="text-2xl font-bold leading-snug mb-3"><%= @post.title %></h1>

      <%# Author info %>
      <div class="flex items-center gap-3">
        <%= link_to creator_profile_path(@creator.username) do %>
          <%= avatar_tag(@creator, size: :sm) %>
        <% end %>
        <div>
          <%= link_to @creator.display_name, creator_profile_path(@creator.username),
                class: "font-semibold text-sm hover:underline" %>
          <p class="text-xs text-gray-400"><%= @post.published_at&.strftime("%Y年%m月%d日") %></p>
        </div>
      </div>
    </div>

    <% if @can_access %>
      <%# Full content %>
      <% if @post.media.attached? %>
        <div class="mb-6 rounded-2xl overflow-hidden grid gap-1 <%= @post.media.count == 1 ? '' : 'grid-cols-2' %>">
          <% @post.media.each do |media_file| %>
            <% if media_file.content_type.start_with?("image/") %>
              <%= image_tag url_for(media_file), class: "w-full object-cover rounded-xl max-h-[500px]" %>
            <% elsif media_file.content_type.start_with?("video/") %>
              <video src="<%= url_for(media_file) %>" controls class="w-full rounded-xl max-h-[500px]"></video>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="prose prose-gray max-w-none text-gray-800 leading-relaxed whitespace-pre-wrap text-[15px]"><%= @post.body %></div>

      <%# Creator CTA footer %>
      <div class="mt-8 pt-6 border-t border-gray-100">
        <div class="flex items-center gap-4 p-4 bg-purple-50 rounded-2xl">
          <%= link_to creator_profile_path(@creator.username) do %>
            <%= avatar_tag(@creator, size: :md) %>
          <% end %>
          <div class="flex-1 min-w-0">
            <%= link_to @creator.display_name, creator_profile_path(@creator.username),
                  class: "font-bold hover:underline" %>
            <% if @creator_profile.tagline.present? %>
              <p class="text-sm text-gray-500 truncate"><%= @creator_profile.tagline %></p>
            <% end %>
          </div>
          <% if !@is_subscribed && @creator_profile.has_subscription_plan? && current_user != @creator %>
            <%= form_with url: fan_subscriptions_path, method: :post, data: { turbo: false } do |f| %>
              <%= f.hidden_field :creator_profile_id, value: @creator_profile.id %>
              <%= f.submit "サポートする",
                    class: "bg-purple-600 hover:bg-purple-700 text-white font-bold text-sm px-4 py-2 rounded-full transition-colors cursor-pointer flex-shrink-0" %>
            <% end %>
          <% end %>
        </div>
      </div>

    <% else %>
      <%# Free preview %>
      <% if @post.free_preview.present? %>
        <div class="mb-6 text-gray-700 leading-relaxed text-[15px]"><%= @post.free_preview %></div>
      <% end %>

      <%# Paywall gate %>
      <div class="relative">
        <%# Blurred fake content %>
        <div class="select-none pointer-events-none mb-0 overflow-hidden rounded-xl" style="max-height: 120px;">
          <div class="text-gray-400 text-sm leading-loose filter blur-sm">
            この先のコンテンツは購読者・購入者のみ閲覧できます。サブスクリプションを開始するか、個別に購入してください。ここには実際のコンテンツの続きが表示されますが、アクセスするには認証が必要です。コンテンツはロックされています。
          </div>
        </div>

        <%# Gradient overlay %>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/70 to-white pointer-events-none"></div>

        <%# Gate card %>
        <div class="relative mt-2 border-2 border-purple-200 rounded-2xl p-6 bg-white text-center shadow-lg shadow-purple-50">
          <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
            </svg>
          </div>
          <h2 class="font-bold text-lg mb-1">プレミアムコンテンツです</h2>
          <p class="text-sm text-gray-500 mb-5">
            <strong><%= @creator.display_name %></strong> のコンテンツを閲覧するには
            <% if @post.ppv? %>
              購入してください
            <% else %>
              サブスクリプションを開始してください
            <% end %>
          </p>

          <% if user_signed_in? %>
            <div class="flex flex-col gap-3 max-w-xs mx-auto">
              <%# PPV purchase button %>
              <% if @post.ppv? %>
                <%= form_with url: premium_purchases_path, method: :post, data: { turbo: false } do |f| %>
                  <%= f.hidden_field :premium_post_id, value: @post.id %>
                  <%= f.submit "¥#{number_with_delimiter(@post.price)} で購入する",
                        class: "w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-full text-sm transition-colors cursor-pointer" %>
                <% end %>
              <% end %>

              <%# Subscription button (always shown if available) %>
              <% if @creator_profile.has_subscription_plan? && !@is_subscribed %>
                <%= form_with url: fan_subscriptions_path, method: :post, data: { turbo: false } do |f| %>
                  <%= f.hidden_field :creator_profile_id, value: @creator_profile.id %>
                  <%= f.submit "¥#{number_with_delimiter(@creator_profile.subscription_price)}/月 サブスクリプションを開始",
                        class: "w-full #{@post.ppv? ? 'border border-purple-300 text-purple-700 hover:bg-purple-50' : 'bg-purple-600 hover:bg-purple-700 text-white'} font-bold py-3 rounded-full text-sm transition-colors cursor-pointer" %>
                <% end %>
                <p class="text-xs text-gray-400">サブスクリプションで全コンテンツにアクセス</p>
              <% end %>
            </div>
          <% else %>
            <div class="flex flex-col gap-3 max-w-xs mx-auto">
              <%= link_to "ログインして購入する", new_user_session_path,
                    class: "block w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-full text-sm transition-colors text-center" %>
              <%= link_to "アカウントを作成する", new_user_registration_path,
                    class: "block w-full border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold py-3 rounded-full text-sm transition-colors text-center" %>
            </div>
          <% end %>

          <% if @creator_profile.payout_enabled? == false %>
            <p class="text-xs text-gray-400 mt-4">このクリエイターはまだ支払い設定を完了していません</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </article>
</div>
