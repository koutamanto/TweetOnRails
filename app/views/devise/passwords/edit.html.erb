<div class="min-h-screen flex items-center justify-center px-6">
  <div class="w-full max-w-sm">
    <div class="mb-8 text-center">
      <%= render "shared/robin_logo", size_class: "w-10 h-10", color_class: "text-sky-500", extra_classes: "mx-auto mb-4" %>
      <h1 class="text-2xl font-bold">新しいパスワードを設定</h1>
    </div>

    <%= form_with model: resource, as: resource_name, url: password_path(resource_name), method: :put, class: "space-y-4" do |f| %>
      <%= f.hidden_field :reset_password_token %>
      <div>
        <%= f.password_field :password, autofocus: true, placeholder: "新しいパスワード（6文字以上）",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
      </div>
      <div>
        <%= f.password_field :password_confirmation, placeholder: "パスワード（確認）",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
      </div>
      <%= f.submit "パスワードを変更", class: "w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-full text-sm transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>
