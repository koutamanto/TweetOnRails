<div class="min-h-screen flex">
  <div class="hidden lg:flex flex-1 bg-sky-500 items-center justify-center">
    <%= render "shared/robin_logo", size_class: "w-48 h-48", color_class: "text-white" %>
  </div>
  <div class="flex-1 flex items-center justify-center px-6 py-12">
    <div class="w-full max-w-sm">
      <div class="lg:hidden mb-8">
        <%= render "shared/robin_logo", size_class: "w-10 h-10", color_class: "text-sky-500" %>
      </div>
      <h1 class="text-3xl font-bold mb-2">アカウントを作成</h1>
      <p class="text-gray-500 text-sm mb-6">登録後すぐにご利用いただけます</p>

      <%= render "shared/flash" %>

      <% if resource.errors.any? %>
        <div class="mb-4 bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700">
          <p class="font-semibold mb-1">入力内容を確認してください</p>
          <ul class="space-y-0.5">
            <% resource.errors.full_messages.each do |msg| %>
              <li>・ <%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), class: "space-y-3.5", data: { turbo: false } do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">表示名</label>
          <%= f.text_field :display_name, autofocus: true, placeholder: "例：田中 太郎",
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ユーザー名</label>
          <div class="flex items-center border border-gray-300 rounded-xl overflow-hidden focus-within:border-sky-500 focus-within:ring-2 focus-within:ring-sky-500/20 transition">
            <span class="pl-4 text-gray-400 text-sm select-none">@</span>
            <%= f.text_field :username, placeholder: "tanaka_taro",
                  class: "flex-1 px-2 py-3 text-sm bg-transparent outline-none" %>
          </div>
          <p class="text-xs text-gray-400 mt-1">3〜20文字、英数字とアンダースコアのみ</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">メールアドレス</label>
          <%= f.email_field :email, placeholder: "you@example.com",
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">パスワード</label>
          <%= f.password_field :password, placeholder: "6文字以上",
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">パスワード（確認）</label>
          <%= f.password_field :password_confirmation, placeholder: "もう一度入力",
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <%= f.submit "登録する", class: "w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-full text-sm transition-colors cursor-pointer mt-1" %>
      <% end %>

      <div class="mt-6 pt-5 border-t border-gray-100 text-center">
        <p class="text-sm text-gray-500 mb-3">すでにアカウントをお持ちですか？</p>
        <%= link_to "ログイン", new_user_session_path,
              class: "block w-full border-2 border-gray-300 text-gray-700 hover:bg-gray-50 font-bold py-2.5 rounded-full text-sm transition-colors text-center" %>
      </div>
    </div>
  </div>
</div>
