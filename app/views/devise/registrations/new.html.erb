<div class="min-h-screen flex">
  <div class="hidden lg:flex flex-1 bg-sky-500 items-center justify-center">
    <%= render "shared/robin_logo", size_class: "w-48 h-48", color_class: "text-white" %>
  </div>
  <div class="flex-1 flex items-center justify-center px-6 py-12">
    <div class="w-full max-w-sm">
      <div class="lg:hidden mb-8">
        <%= render "shared/robin_logo", size_class: "w-10 h-10", color_class: "text-sky-500" %>
      </div>
      <h1 class="text-3xl font-bold mb-8">アカウントを作成</h1>

      <% if resource.errors.any? %>
        <div class="mb-4 bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700">
          <ul class="space-y-0.5">
            <% resource.errors.full_messages.each do |msg| %>
              <li>・ <%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), class: "space-y-4", data: { turbo: false } do |f| %>
        <div>
          <%= f.text_field :display_name, autofocus: true, placeholder: "表示名",
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <div>
          <%= f.text_field :username, placeholder: "ユーザー名（@handle）",
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
          <p class="text-xs text-gray-400 mt-1">3〜20文字、英数字とアンダースコアのみ</p>
        </div>
        <div>
          <%= f.email_field :email, placeholder: "メールアドレス",
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <div>
          <%= f.password_field :password, placeholder: "パスワード（6文字以上）",
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <div>
          <%= f.password_field :password_confirmation, placeholder: "パスワード（確認）",
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <p class="text-xs text-gray-500">登録後すぐにご利用いただけます。</p>
        <%= f.submit "登録する", class: "w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-full text-sm transition-colors cursor-pointer" %>
      <% end %>

      <div class="mt-6 pt-5 border-t border-gray-200 text-center">
        <p class="text-sm text-gray-600 mb-3">すでにアカウントをお持ちですか？</p>
        <%= link_to "ログイン", new_user_session_path, class: "text-sky-500 hover:underline font-medium text-sm" %>
      </div>
    </div>
  </div>
</div>
