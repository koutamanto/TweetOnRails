<div class="min-h-screen flex">
  <div class="hidden lg:flex flex-1 bg-sky-500 items-center justify-center">
    <svg class="w-48 h-48 text-white" viewBox="0 0 24 24" fill="currentColor">
      <path d="M21 9C19 6 17 4 14 3.5C11 3 9 4.5 7 6.5C5 7.5 3 9 2 11C1.5 13 2.5 15 4 16.5C6 18 9 19 12 18.5C15 18 17.5 16.5 19 14.5C21 12.5 21.5 10.5 21 9Z"/><path d="M21 9L24 7.5L24 10.5Z"/>
    </svg>
  </div>
  <div class="flex-1 flex items-center justify-center px-6 py-12">
    <div class="w-full max-w-sm">
      <div class="lg:hidden mb-8">
        <svg class="w-10 h-10 text-sky-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21 9C19 6 17 4 14 3.5C11 3 9 4.5 7 6.5C5 7.5 3 9 2 11C1.5 13 2.5 15 4 16.5C6 18 9 19 12 18.5C15 18 17.5 16.5 19 14.5C21 12.5 21.5 10.5 21 9Z"/><path d="M21 9L24 7.5L24 10.5Z"/>
        </svg>
      </div>
      <h1 class="text-3xl font-bold mb-8">Robinにログイン</h1>

      <%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "space-y-4" do |f| %>
        <div>
          <%= f.email_field :email, autofocus: true, placeholder: "メールアドレス",
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <div>
          <%= f.password_field :password, placeholder: "パスワード",
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
        </div>
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "rounded" %>
            <%= f.label :remember_me, "ログイン状態を保持", class: "text-sm text-gray-600" %>
          </div>
        <% end %>
        <%= f.submit "ログイン", class: "w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-full text-sm transition-colors cursor-pointer" %>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "パスワードをお忘れですか？", new_user_password_path, class: "text-sm text-sky-500 hover:underline" %>
      </div>

      <div class="mt-8 pt-6 border-t border-gray-200 text-center">
        <p class="text-sm text-gray-600 mb-4">アカウントをお持ちでないですか？</p>
        <%= link_to "新規登録", new_user_registration_path, class: "border-2 border-sky-500 text-sky-500 hover:bg-sky-50 font-bold py-3 px-8 rounded-full text-sm transition-colors inline-block" %>
      </div>
    </div>
  </div>
</div>
