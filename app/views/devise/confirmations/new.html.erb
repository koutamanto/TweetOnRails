<div class="min-h-screen flex items-center justify-center px-6">
  <div class="w-full max-w-sm text-center">
    <svg class="w-10 h-10 text-sky-500 mx-auto mb-6" viewBox="0 0 24 24" fill="currentColor">
      <path d="M21 9C19 6 17 4 14 3.5C11 3 9 4.5 7 6.5C5 7.5 3 9 2 11C1.5 13 2.5 15 4 16.5C6 18 9 19 12 18.5C15 18 17.5 16.5 19 14.5C21 12.5 21.5 10.5 21 9Z"/><path d="M21 9L24 7.5L24 10.5Z"/>
    </svg>
    <h1 class="text-2xl font-bold mb-2">確認メールを再送</h1>
    <p class="text-gray-500 text-sm mb-6">登録したメールアドレスを入力してください</p>

    <%= form_with model: resource, as: resource_name, url: confirmation_path(resource_name), method: :post, class: "space-y-4 text-left" do |f| %>
      <div>
        <%= f.email_field :email, autofocus: true, placeholder: "メールアドレス",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20 transition" %>
      </div>
      <%= f.submit "確認メールを再送", class: "w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-full text-sm transition-colors cursor-pointer" %>
    <% end %>

    <div class="mt-4">
      <%= link_to "ログインに戻る", new_user_session_path, class: "text-sm text-sky-500 hover:underline" %>
    </div>
  </div>
</div>
