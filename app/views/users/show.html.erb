<% content_for :seo_title, "#{@user.display_name} (@#{@user.username})" %>
<% content_for :seo_desc, [@user.bio.presence, "#{@user.tweets_count}ツイート · #{@user.followers_count}フォロワー"].compact.join(" — ").truncate(160) %>
<% content_for :seo_image, absolute_avatar_url(@user) %>
<% content_for :seo_canonical, "https://robin.katskouta.one/#{@user.username}" %>
<% content_for :structured_data do %>
<%= breadcrumb_json_ld([
  {name: "ホーム", url: "https://robin.katskouta.one/"},
  {name: "@#{@user.username}", url: "https://robin.katskouta.one/#{@user.username}"}
]) %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": <%= @user.display_name.to_json.html_safe %>,
    "alternateName": "@<%= @user.username %>",
    "identifier": "@<%= @user.username %>",
    "url": "https://robin.katskouta.one/<%= @user.username %>",
    "image": "<%= absolute_avatar_url(@user) %>",
    "description": <%= @user.bio.to_s.to_json.html_safe %>,
    <% if @user.location.present? %>"homeLocation": {"@type":"Place","name": <%= @user.location.to_json.html_safe %>},<% end %>
    <% if @user.website.present? %>"sameAs": [<%= (@user.website.start_with?("http") ? @user.website : "https://#{@user.website}").to_json.html_safe %>],<% end %>
    "interactionStatistic": [
      {"@type":"InteractionCounter","interactionType":"https://schema.org/FollowAction","userInteractionCount":<%= @user.followers_count %>}
    ]
  },
  "dateModified": "<%= @user.updated_at.iso8601 %>"
}
</script>
<% end %>

<div class="sticky top-0 bg-white/80 backdrop-blur-sm border-b border-gray-100 px-4 py-3 z-10 flex items-center gap-4">
  <%= link_to :back, class: "p-2 rounded-full hover:bg-gray-100 transition-colors -ml-2" do %>
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
  <% end %>
  <div>
    <h1 class="font-bold text-xl leading-tight"><%= @user.display_name %></h1>
    <p class="text-xs text-gray-500"><%= @user.tweets_count %> ツイート</p>
  </div>
</div>

<%# Header image %>
<div class="relative">
  <div class="h-48 bg-sky-100 overflow-hidden">
    <% if @user.header_image.attached? %>
      <%= image_tag url_for(@user.header_image), class: "w-full h-full object-cover" %>
    <% end %>
  </div>

  <div class="absolute bottom-0 translate-y-1/2 left-4">
    <%= avatar_tag(@user, size: :xl) %>
  </div>
</div>

<div class="px-4 pt-14 pb-4 border-b border-gray-100">
  <div class="flex justify-end mb-3">
    <% if user_signed_in? && @user == current_user %>
      <%= link_to settings_profile_path, class: "border border-gray-300 hover:bg-gray-50 font-bold text-sm px-4 py-1.5 rounded-full transition-colors" do %>
        プロフィールを編集
      <% end %>
    <% else %>
      <div class="flex items-center gap-2">
        <% if user_signed_in? %>
          <%= button_to conversations_path(recipient_id: @user.id), method: :post,
                class: "border border-gray-300 hover:bg-gray-50 p-1.5 rounded-full transition-colors" do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          <% end %>
        <% end %>
        <%= render "users/follow_btn", user: @user, current_user: current_user %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center gap-1.5">
    <h2 class="font-bold text-xl"><%= @user.display_name %></h2>
    <%= render "shared/pro_badge", user: @user %>
  </div>
  <p class="text-gray-500 text-sm mb-2">@<%= @user.username %></p>
  <% if @user.bio.present? %>
    <p class="text-[15px] mb-3"><%= @user.bio %></p>
  <% end %>

  <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500 mb-3">
    <% if @user.location.present? %>
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
        <%= @user.location %>
      </span>
    <% end %>
    <% if @user.website.present? %>
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
        <%= link_to @user.website, @user.website.start_with?("http") ? @user.website : "https://#{@user.website}", class: "text-sky-500 hover:underline", target: "_blank", rel: "noopener" %>
      </span>
    <% end %>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5"/></svg>
      <%= @user.created_at.strftime("%Y年%m月") %>から利用
    </span>
  </div>

  <div class="flex gap-5 text-sm">
    <%= link_to following_user_path(@user.username), class: "hover:underline" do %>
      <strong><%= @user.following_count %></strong> <span class="text-gray-500">フォロー中</span>
    <% end %>
    <%= link_to followers_user_path(@user.username), class: "hover:underline" do %>
      <strong><%= @user.followers_count %></strong> <span class="text-gray-500">フォロワー</span>
    <% end %>
  </div>

  <% if @user.creator_profile.present? %>
    <div class="mt-3">
      <%= link_to creator_profile_path(@user.username), class: "inline-flex items-center gap-2 bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-700 text-sm font-medium px-3 py-1.5 rounded-full transition-colors" do %>
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
        クリエイターページ
      <% end %>
    </div>
  <% end %>
</div>

<%# Profile tabs %>
<div class="flex border-b border-gray-100">
  <%= link_to user_path(@user.username), class: "flex-1 text-center py-3 text-sm font-medium hover:bg-gray-50 transition-colors border-b-2 #{action_name == 'show' ? 'border-sky-500 text-sky-500' : 'border-transparent text-gray-500'}" do %>ツイート<% end %>
  <%= link_to media_user_path(@user.username), class: "flex-1 text-center py-3 text-sm font-medium hover:bg-gray-50 transition-colors border-b-2 #{action_name == 'media' ? 'border-sky-500 text-sky-500' : 'border-transparent text-gray-500'}" do %>メディア<% end %>
  <%= link_to likes_user_path(@user.username), class: "flex-1 text-center py-3 text-sm font-medium hover:bg-gray-50 transition-colors border-b-2 #{action_name == 'likes' ? 'border-sky-500 text-sky-500' : 'border-transparent text-gray-500'}" do %>いいね<% end %>
</div>

<div id="tweets">
  <% @tweets.each do |tweet| %>
    <%= render "shared/tweet_card", tweet: tweet, current_user: current_user %>
  <% end %>
</div>

<% if @tweets.empty? %>
  <div class="text-center py-16 text-gray-400">
    <p class="font-medium">まだツイートがありません</p>
  </div>
<% end %>
