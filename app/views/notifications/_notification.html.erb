<div class="flex items-start gap-3 px-4 py-3 border-b border-gray-100 hover:bg-gray-50 transition-colors <%= notification.unread? ? 'bg-sky-50/30' : '' %>">
  <div class="flex-shrink-0 mt-1">
    <% case notification.action %>
    <% when "liked" %>
      <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center">
        <svg class="w-4 h-4 text-red-500" viewBox="0 0 24 24" fill="currentColor"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg>
      </div>
    <% when "followed" %>
      <div class="w-8 h-8 bg-sky-100 rounded-full flex items-center justify-center">
        <svg class="w-4 h-4 text-sky-500" fill="currentColor" viewBox="0 0 20 20"><path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h-1V7z"/></svg>
      </div>
    <% when "retweeted" %>
      <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
        <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
      </div>
    <% when "replied", "mentioned" %>
      <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center">
        <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 01-.923 1.785A5.969 5.969 0 006 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337z"/></svg>
      </div>
    <% end %>
  </div>

  <div class="flex-1 min-w-0">
    <%= link_to user_path(notification.actor.username) do %>
      <%= avatar_tag(notification.actor, size: :sm) %>
    <% end %>
    <p class="text-sm mt-1">
      <strong><%= notification.actor.display_name %></strong>
      <% case notification.action %>
      <% when "liked" %>さんがあなたのツイートにいいねしました
      <% when "followed" %>さんがあなたをフォローしました
      <% when "retweeted" %>さんがあなたのツイートをリツイートしました
      <% when "replied" %>さんがあなたのツイートに返信しました
      <% when "mentioned" %>さんがあなたをメンションしました
      <% end %>
    </p>
    <% if notification.notifiable.is_a?(Tweet) %>
      <p class="text-sm text-gray-500 mt-0.5 truncate"><%= notification.notifiable.body %></p>
    <% end %>
    <p class="text-xs text-gray-400 mt-0.5"><%= relative_time(notification.created_at) %></p>
  </div>
</div>
