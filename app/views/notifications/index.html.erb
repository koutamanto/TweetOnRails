<div class="sticky top-0 bg-white/80 backdrop-blur-sm border-b border-gray-100 px-4 py-3 z-10">
  <h1 class="font-bold text-xl">通知</h1>
</div>

<% if @notifications.any? %>
  <% @notifications.each do |notification| %>
    <%= render "notifications/notification", notification: notification %>
  <% end %>
<% else %>
  <div class="text-center py-16 px-4">
    <div class="w-16 h-16 bg-sky-50 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
      </svg>
    </div>
    <h2 class="font-bold text-2xl mb-2">通知はありません</h2>
    <p class="text-gray-500">いいね、リツイート、フォローなどの通知がここに表示されます</p>
  </div>
<% end %>
